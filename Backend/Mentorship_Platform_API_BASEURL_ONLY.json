              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('studentToken', jsonData.data.token);",
                  "    pm.environment.set('studentId', jsonData.data.user.id);",
                  "    pm.environment.set('currentToken', jsonData.data.token);",
                  "    console.log('Student Registered Successfully');",
                  "    console.log('Student Token:', jsonData.data.token.substring(0, 30) + '...');",
                  "    console.log('Student ID:', jsonData.data.user.id);",
                  "}"
