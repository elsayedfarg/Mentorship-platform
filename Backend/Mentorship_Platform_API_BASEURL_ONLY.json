            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('sessionId', jsonData.data._id);",
                  "    console.log('Session Booked Successfully');",
                  "    console.log('Session ID:', jsonData.data._id);",
                  "    console.log('Status:', jsonData.data.status);",
                  "    if (jsonData.data.sessionAuditLog) {",
                  "        pm.environment.set('auditLogId', jsonData.data.sessionAuditLog._id);",
                  "        console.log('AI Audit Log ID:', jsonData.data.sessionAuditLog._id);",
                  "        console.log('AI Prediction:', jsonData.data.sessionAuditLog.predicted_tag);",
                  "        console.log('Confidence Score:', jsonData.data.sessionAuditLog.confidence_score);",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{studentToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
